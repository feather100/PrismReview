# Database
DATABASE_URL="postgresql://prismreview:prismreview@localhost:5432/prismreview?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Object Storage (MinIO)
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="<change-me>"
MINIO_SECRET_KEY="<change-me>"
MINIO_BUCKET="prismreview"

# Web
WEB_ORIGIN="http://localhost:3000"

# API
PORT=4000

# ── AI Model Provider ──
# Provider selection: "mock" (default) | "lmstudio" | "openai_compatible"
MODEL_PROVIDER="mock"

# Production safety gate: must be "true" to allow external model calls
ALLOW_EXTERNAL_MODEL_CALLS=false

# Base URL for LM Studio or OpenAI-compatible API
# Default: http://127.0.0.1:1234/v1 (LM Studio)
# MODEL_BASE_URL="http://127.0.0.1:1234/v1"

# Model name (default: google/gemma-4-12b)
# MODEL_NAME="google/gemma-4-12b"

# API Key for OpenAI-compatible providers (NOT used for LM Studio)
# WARNING: Never commit real API keys to Git. Use .env.local or env vars.
# MODEL_API_KEY="sk-..."

# Timeout in milliseconds (default: 120000)
# MODEL_TIMEOUT_MS=120000

# Max tokens for completion (default: 2048)
# MODEL_MAX_TOKENS=2048

# Budget guard — single session budget limit in USD (default: $0.10)
# MODEL_BUDGET_LIMIT=0.10

# Daily call limit guard (default: 100)
# MODEL_DAILY_CALL_LIMIT=100

# ── Dev Pilot (Sprint 7.3 — Dev-only Queue LM Studio Pilot) ──
# Hard cap on the number of roles dispatched per review WHEN the dev-only
# LM Studio pilot is active (MODEL_PROVIDER=lmstudio + ALLOW_EXTERNAL_MODEL_CALLS=true).
# This is a dev-pilot-only control and NEVER affects default / mock reviews —
# the default mock demo remains unchanged regardless of this value.
#   • Unset / empty      → defaults to 3 (single review ≤ 3 roles, per contract §3/§10)
#   • Positive integer   → that many roles max
#   • Invalid value      → falls back to 3
# Requires a real LM Studio endpoint + explicit env guard to take effect; do NOT
# set this (or MODEL_PROVIDER=lmstudio) in production / CI / default demo.
# MODEL_PILOT_MAX_ROLES=3

# Worker
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
